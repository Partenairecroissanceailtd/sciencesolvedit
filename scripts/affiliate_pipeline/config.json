  "filters": {
    "min_commission": 5,
    "min_cookie_days": 7,
    "target_geo": ["US", "CA", "UK", "AU"],
    "target_niches": [
      "red-light-therapy",
      "cold-plunge",
      "pemf",
      "wearables",
      "sauna",
      "biohacking",
      "supplements",
      "health-monitoring",
      "home-health",
      "ergonomics",
      "wellness"
    ],
    "exclude_kyc": true
  },
  "domain": {
    "name": "Science Solved It",
    "concept": "Science evidence-based solutions — anything where data, research, and engineering improve human performance, health, or daily life.",
    "relevance_keywords": [
      "red light therapy",
      "cold plunge",
      "ice bath",
      "PEMF therapy",
      "wearable health tracker",
      "sauna benefits",
      "biohacking devices",
      "nootropics",
      "sleep optimization",
      "HRV monitoring",
      "light therapy panel",
      "cryotherapy",
      "grounding mat",
      "air purifier",
      "water filter",
      "ergonomic chair",
      "standing desk",
      "blue light blocking",
      "sleep tracker",
      "fitness tracker",
      "smart ring",
      "blood pressure monitor",
      "continuous glucose monitor",
      "supplements",
      "vitamin d lamp",
      "massage gun",
      "foam roller",
      "posture corrector"
    ],
    "min_relevance_score": 2,
    "expansion_rule": "If the product solves a measurable human problem and has research/studies backing it, it fits. Creative freedom within 'science + solution.'"
  },
  "apify": {
    "api_key_env": "APIFY_API_KEY"
  },
  "demand_research": {
    "apify_actor": "junglee/free-amazon-product-scraper",
    "data_sources": ["Google Keyword Planner", "Ahrefs", "Apify Actors"],
    "min_monthly_searches": 1000,
    "competitor_overlap_threshold": 0.3
  },
  "publishing": {
    "output_dir": "../content/reviews",
    "auto_publish": false,
    "disclosure_text": "We earn a commission if you purchase through our links, at no extra cost to you."
  }
}
