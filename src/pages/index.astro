---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const reviews = await getCollection('reviews');
const guides = await getCollection('guides');
const comparisons = await getCollection('comparisons');
---

<BaseLayout 
  title="Science Solved It — Evidence-Based Biohacking & Hardware Reviews"
  description="Independent, research-backed reviews of red light therapy, cold plunge, PEMF, wearables, and biohacking hardware. Find the best gear for your body."
  breadcrumbs={[{ name: 'Home', url: '/' }]}
>
  <section class="hero">
    <div class="container" style="text-align:center; padding:4rem 0">
      <h1 style="font-size:3rem; margin-bottom:1rem">
        Science <span style="color:var(--accent)">Solved It</span>
      </h1>
      <p style="font-size:1.2rem; max-width:650px; margin:0 auto 2rem">
        Evidence-based reviews of biohacking hardware, wearables, and performance gear. 
        We test the claims so you can make informed decisions.
      </p>
      <div class="btns" style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap">
        <a href="/reviews/" class="btn btn-primary">Browse Reviews</a>
        <a href="/guides/" class="btn btn-outline">Buyer's Guides</a>
      </div>
    </div>
  </section>

  <!-- Latest Reviews -->
  <section class="container" style="padding:2rem 0">
    <h2 style="margin-bottom:1.5rem">Latest Reviews</h2>
    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(320px, 1fr)); gap:1.5rem">
      {reviews.slice(-6).reverse().map(r => {
        const reviewSlug = r.id.replace('reviews/', '');
        return (
        <a href={`/reviews/${reviewSlug}/`} style="text-decoration:none; color:inherit">
          <div class="card">
            <div style="display:flex; justify-content:space-between; align-items:start; margin-bottom:0.75rem">
              <span class="tag" style="background:var(--accent)">{r.data.category}</span>
              <span class="price-badge" style="font-size:0.9rem">${r.data.price}</span>
            </div>
            <h3 style="margin-bottom:0.5rem; font-size:1.15rem">{r.data.title}</h3>
            <p style="font-size:0.9rem; color:var(--text-muted)">{r.data.description}</p>
            <div style="margin-top:0.75rem; font-size:0.85rem; color:var(--green)">
              ★ {r.data.rating}/5 — {r.data.pros?.length || 0} pros, {r.data.cons?.length || 0} cons
            </div>
          </div>
        </a>
      );})}
    </div>
    <div style="text-align:center; margin-top:2rem">
      <a href="/reviews/" class="btn btn-outline">View All Reviews →</a>
    </div>
  </section>

  <!-- Featured Guides -->
  <section class="container" style="padding:3rem 0">
    <h2 style="margin-bottom:1.5rem">Buyer's Guides</h2>
    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(320px, 1fr)); gap:1.5rem">
      {guides.slice(-4).reverse().map(g => {
        const guideSlug = g.id.replace('guides/', '');
        return (
        <a href={`/guides/${guideSlug}/`} style="text-decoration:none; color:inherit">
          <div class="card">
            <h3 style="margin-bottom:0.5rem">{g.data.title}</h3>
            <p style="font-size:0.9rem; color:var(--text-muted)">{g.data.description}</p>
            <div style="margin-top:0.75rem; font-size:0.85rem; color:var(--text-muted)">
              {g.data.products} products compared
            </div>
          </div>
        </a>
      );})}
    </div>
    <div style="text-align:center; margin-top:2rem">
      <a href="/guides/" class="btn btn-outline">All Buyer's Guides →</a>
    </div>
  </section>

  <!-- By Category -->
  <section class="container" style="padding:2rem 0 4rem">
    <h2 style="margin-bottom:1.5rem">Shop by Category</h2>
    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(220px, 1fr)); gap:1rem">
      <a href="/category/red-light-therapy/" class="card" style="text-align:center; text-decoration:none; color:inherit; padding:2rem 1rem">
        <div style="font-size:2.5rem; margin-bottom:0.5rem">🔴</div>
        <h3 style="font-size:1rem">Red Light Therapy</h3>
        <p style="font-size:0.85rem">Panels, masks, belts</p>
      </a>
      <a href="/category/cold-plunge/" class="card" style="text-align:center; text-decoration:none; color:inherit; padding:2rem 1rem">
        <div style="font-size:2.5rem; margin-bottom:0.5rem">🧊</div>
        <h3 style="font-size:1rem">Cold Plunge</h3>
        <p style="font-size:0.85rem">Tubs, chillers, accessories</p>
      </a>
      <a href="/category/pemf/" class="card" style="text-align:center; text-decoration:none; color:inherit; padding:2rem 1rem">
        <div style="font-size:2.5rem; margin-bottom:0.5rem">🧲</div>
        <h3 style="font-size:1rem">PEMF Therapy</h3>
        <p style="font-size:0.85rem">Mats, pads, devices</p>
      </a>
      <a href="/category/wearables/" class="card" style="text-align:center; text-decoration:none; color:inherit; padding:2rem 1rem">
        <div style="font-size:2.5rem; margin-bottom:0.5rem">⌚</div>
        <h3 style="font-size:1rem">Wearables</h3>
        <p style="font-size:0.85rem">HRV, sleep, recovery</p>
      </a>
      <a href="/category/sauna/" class="card" style="text-align:center; text-decoration:none; color:inherit; padding:2rem 1rem">
        <div style="font-size:2.5rem; margin-bottom:0.5rem">♨️</div>
        <h3 style="font-size:1rem">Sauna</h3>
        <p style="font-size:0.85rem">Infrared, blankets</p>
      </a>
    </div>
  </section>
</BaseLayout>
