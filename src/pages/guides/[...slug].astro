---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, getEntry, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('guides');
  return entries.map(entry => ({
    params: { slug: entry.id.replace('guides/', '') },
    props: { id: entry.id }
  }));
}

const { id } = Astro.props;
const entry = await getEntry('guides', id);
const { Content } = await render(entry);
const slug = id.replace('guides/', '');
---

<BaseLayout
  title={`${entry.data.title} — Science Solved It`}
  description={entry.data.description}
  type="article"
  publishedTime={entry.data.publishedDate?.toISOString()}
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Guides', url: '/guides/' },
    { name: entry.data.title, url: `/guides/${slug}/` }
  ]}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": entry.data.title,
    "description": entry.data.description,
    "datePublished": entry.data.publishedDate?.toISOString()
  }}
>
  <article class="container-narrow" style="padding:2rem 0">
    <div style="margin-bottom:2rem">
      <div style="display:flex; gap:0.5rem; flex-wrap:wrap; margin-bottom:1rem">
        <span class="tag">{entry.data.category.replace(/-/g, ' ')}</span>
        <span class="tag-amber">{entry.data.products} products compared</span>
      </div>
      <h1>{entry.data.title}</h1>
      <p style="font-size:1.1rem; color:var(--text-muted); margin-top:0.75rem">{entry.data.description}</p>
    </div>

    <div class="affiliate-disclosure">
      We earn a commission if you purchase through our links, at no extra cost to you.
    </div>

    <div class="prose">
      <Content />
    </div>

    <div style="margin-top:3rem; padding-top:1.5rem; border-top:1px solid var(--border)">
      <a href="/guides/" style="color:var(--text-muted)">← All Buyer's Guides</a>
    </div>
  </article>
</BaseLayout>
